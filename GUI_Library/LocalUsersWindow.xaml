<Window x:Class="GUI_Library.LocalUsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="Local Users" Height="760" Width="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Grid.Row="0" Text="Local Users"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- ENABLE TOGGLE -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <ToggleButton x:Name="EnabledToggle"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              VerticalAlignment="Center"/>
                <TextBlock Text="Enable local users"
                           VerticalAlignment="Center" Margin="12,0,0,0"
                           FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock TextWrapping="Wrap" FontSize="11" Opacity="0.6"
                       Margin="0,4,0,0"
                       Text="Local users are a fallback: they can only log in when Active Directory is unreachable (or when no AD is configured). Leave this off on sites with healthy AD."/>
        </StackPanel>

        <!-- LIST HEADER -->
        <TextBlock Grid.Row="2" Text="USERS" FontWeight="Bold" FontSize="12"
                   Opacity="0.7" Margin="0,12,0,8"/>

        <!-- USER LIST -->
        <Border Grid.Row="3" BorderThickness="1" CornerRadius="4"
                BorderBrush="#33000000" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="UsersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Username}"
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>

                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding DataContext.AllRoles,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                          SelectedItem="{Binding Role, Mode=TwoWay}"
                                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                          Margin="0,0,8,0"/>

                                <Button Grid.Column="2" Content="RESET PW"
                                        Click="ResetPassword_Click"
                                        Tag="{Binding Username}"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Margin="0,0,8,0" Padding="8,0"/>

                                <Button Grid.Column="3"
                                        Click="Delete_Click"
                                        Tag="{Binding Username}"
                                        Style="{StaticResource MaterialDesignIconButton}"
                                        ToolTip="Delete user">
                                    <materialDesign:PackIcon Kind="Delete"/>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ADD NEW USER -->
        <StackPanel Grid.Row="4" Margin="0,16,0,0">
            <TextBlock Text="ADD USER" FontWeight="Bold" FontSize="12"
                       Opacity="0.7" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="NewUserBox" Grid.Column="0"
                         materialDesign:HintAssist.Hint="Username"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                <PasswordBox x:Name="NewPasswordBox" Grid.Column="2"
                             materialDesign:HintAssist.Hint="Password"
                             Style="{StaticResource MaterialDesignOutlinedRevealPasswordBox}"/>

                <ComboBox x:Name="NewRoleCombo" Grid.Column="4"
                          materialDesign:HintAssist.Hint="Role"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"/>

                <Button Grid.Column="6" Content="ADD" Click="Add_Click"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="AddStatus" Text="" FontSize="11" Opacity="0.8"
                       TextWrapping="Wrap" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="CANCEL" Click="Cancel_Click"
                    Style="{StaticResource MaterialDesignOutlinedButton}"
                    Width="110" Margin="0,0,8,0"/>
            <Button Content="SAVE" Click="Save_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Width="110"/>
        </StackPanel>
    </Grid>
</Window>
