<UserControl x:Class="SDK_GUI_Test1.CameraPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:controls="clr-namespace:VisionSDK.AddOn.Wpf.Controls;assembly=VisionSDK.AddOn.Wpf"
             xmlns:local="clr-namespace:SDK_GUI_Test1"
             xmlns:shared="clr-namespace:GUI_Library;assembly=GUI_Library">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="24"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- VENSTRE: kontroller -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Titel -->
                <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

                <!-- STATUS: Online + Connected -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Ellipse Width="16" Height="16" VerticalAlignment="Center"
                                 Fill="{Binding IsOnline, Converter={StaticResource BoolToStatusBrush}}"/>
                            <TextBlock Text="{Binding OnlineText}" Margin="8,0,0,0"
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Ellipse Width="16" Height="16" VerticalAlignment="Center"
                                 Fill="{Binding IsConnected, Converter={StaticResource BoolToStatusBrush}}"/>
                            <TextBlock Text="{Binding ConnectionText}" Margin="8,0,0,0"
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

                <!-- BRUGER -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="BRUGER" FontWeight="Bold" FontSize="12" Opacity="0.7" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{Binding LoginButtonText}"
                                Command="{Binding LoginCommand}"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                            <Button Grid.Column="2" Content="Gem program"
                                Command="{Binding SaveProgramCommand}"
                                IsEnabled="{Binding CanSaveProgram}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </Grid>
                        <TextBlock Text="{Binding CurrentUser, StringFormat=Logget ind som: {0}}"
                               Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}"
                               FontSize="12" Opacity="0.7" Margin="0,8,0,0"/>

                        <!-- Advarsel: aendring er aktiv i kameraet men ikke gemt til .vp. -->
                        <Border Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVis}}"
                                Background="#FFF3CD" CornerRadius="4" Padding="10,6" Margin="0,10,0,0">
                            <TextBlock Text="Ugemte aendringer - tryk 'Gem program' for at goere dem permanente"
                                       Foreground="#856404" FontSize="12" TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </materialDesign:Card>

                <!-- MANUEL BETJENING -->
                <materialDesign:Card Padding="16" Margin="0,0,0,16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="MANUEL BETJENING" FontWeight="Bold" FontSize="12" Opacity="0.7" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Online" Command="{Binding OnlineCommand}"
                                IsEnabled="{Binding CanOperate}"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                            <Button Grid.Column="2" Content="Offline" Command="{Binding OfflineCommand}"
                                IsEnabled="{Binding CanOperate}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            <Button Grid.Column="4" Content="Trig" Command="{Binding TriggerCommand}"
                                IsEnabled="{Binding CanOperate}"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- TOOL: GAUGE (kameraspecifik) -->
                <materialDesign:Card Padding="16"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="GAUGE" FontWeight="Bold" FontSize="12"
                               Opacity="0.7" Margin="0,0,0,12"/>

                        <!-- Aktuel maalt vaerdi (Distance List.element) + pass/fail-maerke. -->
                        <DockPanel Margin="0,0,0,12">
                            <Border DockPanel.Dock="Right" VerticalAlignment="Center"
                                    CornerRadius="4" Padding="14,4"
                                    Background="{Binding GaugePass,
                                                 Converter={StaticResource BoolToStatusBrush}}">
                                <TextBlock Text="{Binding GaugePassText}"
                                           Foreground="White" FontWeight="Bold" FontSize="13"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Aktuel" FontSize="12" Opacity="0.6"/>
                                <controls:PropertyBlock
                                    FontSize="28" FontWeight="Bold"
                                    PropertyPort="{Binding Source={x:Static local:VisionPorts.GAUGE_MEASURED},
                                                   Converter={StaticResource StringToVisionPortConverter}}"
                                    VisionDeviceWrapper="{Binding Device}"
                                    ExternalTrigger="{Binding ExternalTrigger}"/>
                            </StackPanel>
                        </DockPanel>

                        <!-- AddOn-visning af HELE tolerance-porten (minus/nominal/plus). -->
                        <Separator Margin="0,16,0,8"/>
                        <TextBlock Text="Tolerance (VPM)" FontSize="12"
                                   Opacity="0.6" Margin="0,0,0,6"/>
                        <controls:PropertyTolerance
                            PropertyPort="{Binding Source={x:Static local:VisionPorts.GAUGE_TOLERANCE},
                                           Converter={StaticResource StringToVisionPortConverter}}"
                            VisionDeviceWrapper="{Binding Device}"
                            ExternalTrigger="{Binding ExternalTrigger}"
                            IsEnabled="{Binding CanEditGauge}"
                            EnableKeyboard="True"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- TOOL: BLOB (kameraspecifik) -->
                <materialDesign:Card Padding="16" Margin="0,16,0,0"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                    <StackPanel>
                        <TextBlock Text="BLOB" FontWeight="Bold" FontSize="12"
                               Opacity="0.7" Margin="0,0,0,12"/>

                        <!-- Aktuelt antal fundne blobs + pass/fail-maerke. -->
                        <DockPanel Margin="0,0,0,12">
                            <Border DockPanel.Dock="Right" VerticalAlignment="Center"
                                    CornerRadius="4" Padding="14,4"
                                    Background="{Binding BlobPass,
                                                 Converter={StaticResource BoolToStatusBrush}}">
                                <TextBlock Text="{Binding BlobPassText}"
                                           Foreground="White" FontWeight="Bold" FontSize="13"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Antal blobs" FontSize="12" Opacity="0.6"/>
                                <controls:PropertyBlock
                                    FontSize="28" FontWeight="Bold"
                                    PropertyPort="{Binding Source={x:Static local:VisionPorts.BLOB_COUNT},
                                                   Converter={StaticResource StringToVisionPortConverter}}"
                                    VisionDeviceWrapper="{Binding Device}"
                                    ExternalTrigger="{Binding ExternalTrigger}"/>
                            </StackPanel>
                        </DockPanel>

                        <Separator Margin="0,0,0,8"/>

                        <!-- Required Number Of Blobs (Range 1D: min/max). -->
                        <TextBlock Text="Antal blobs (min / max)" FontSize="12"
                                   Opacity="0.6" Margin="0,0,0,6"/>
                        <controls:PropertyTolerance
                            PropertyPort="{Binding Source={x:Static local:VisionPorts.BLOB_REQUIRED},
                                           Converter={StaticResource StringToVisionPortConverter}}"
                            VisionDeviceWrapper="{Binding Device}"
                            ExternalTrigger="{Binding ExternalTrigger}"
                            IsEnabled="{Binding CanEditBlob}"
                            EnableKeyboard="True"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- HOEJRE: live billede via ImageViewer (AddOn) -->
        <materialDesign:Card Grid.Column="2" Padding="12"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="BILLEDE" FontWeight="Bold"
                           FontSize="12" Opacity="0.7" Margin="4,4,0,12"/>
                <controls:ImageViewer
                    ImagePort="{Binding Source={x:Static local:VisionPorts.IMAGE},
                                Converter={StaticResource StringToVisionPortConverter}}"
                    ResultPort="{Binding Source={x:Static local:VisionPorts.GAUGE_RESULT},
                                 Converter={StaticResource StringToVisionPortConverter}}"
                    VisionDeviceWrapper="{Binding Device}"
                    ExternalTrigger="{Binding ExternalTrigger}"/>
            </DockPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
