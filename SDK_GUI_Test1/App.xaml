<Application x:Class="SDK_GUI_Test1.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:SDK_GUI_Test1"
             xmlns:shared="clr-namespace:GUI_Library;assembly=GUI_Library"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="BlueGrey" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/VisionSDK.AddOn.Wpf;component/Converters/Converters.xaml" />
                <ResourceDictionary Source="pack://application:,,,/VisionSDK.AddOn.Wpf;component/Themes/Generic/Buttons.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Egne converters -->
            <shared:BoolToStatusBrush x:Key="BoolToStatusBrush" />
            <shared:BoolToVis x:Key="BoolToVis" />
            <shared:InverseBoolToVis x:Key="InverseBoolToVis" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
