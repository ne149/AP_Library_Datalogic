<!-- Main window makes the GUI for the whole window -->
    <Window x:Class="SDK_GUI_Test1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:controls="clr-namespace:VisionSDK.AddOn.Wpf.Controls;assembly=VisionSDK.AddOn.Wpf"
        xmlns:local="clr-namespace:SDK_GUI_Test1"
        xmlns:shared="clr-namespace:GUI_Library;assembly=GUI_Library"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Background="{DynamicResource MaterialDesignPaper}"
        Title="1349 - Vision GUI" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <materialDesign:ColorZone Grid.Row="0" Mode="PrimaryDark" Padding="16"
                                  materialDesign:ElevationAssist.Elevation="Dp4">
            <TextBlock Text="1349 - Box Inspection" FontSize="20" FontWeight="Bold"/>
        </materialDesign:ColorZone>

        <!-- TABS -->
        <TabControl Grid.Row="1" Margin="0">

            <!-- ===== HOMEPAGE: Overview ===== -->
            <TabItem Header="Homepage">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Cameras}" Margin="16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Margin="8" Padding="10"
                                                     VerticalAlignment="Top"
                                                     materialDesign:ElevationAssist.Elevation="Dp2">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="{Binding Title}"
                                                   FontWeight="SemiBold" FontSize="13"
                                                   Margin="2,0,0,8"/>
                                        <Border CornerRadius="4" BorderThickness="1" Height="200"
                                                VerticalAlignment="Top"
                                                BorderBrush="#33000000"
                                                Background="#11000000">
                                            <Grid>
                                                <controls:ImageViewer
                                                    ImagePort="{Binding Source={x:Static local:VisionPorts.IMAGE},
                                                                Converter={StaticResource StringToVisionPortConverter}}"
                                                    ResultPort="{Binding Source={x:Static local:VisionPorts.GAUGE_RESULT},
                                                                 Converter={StaticResource StringToVisionPortConverter}}"
                                                    VisionDeviceWrapper="{Binding Device}"
                                                    ExternalTrigger="{Binding ExternalTrigger}"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                                <TextBlock Text="No Camera"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Opacity="0.4" FontSize="14"
                                                           Visibility="{Binding IsActive, Converter={StaticResource InverseBoolToVis}}"/>
                                            </Grid>
                                        </Border>
                                    </DockPanel>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <!-- ===== CAMERA 1 ===== -->
            <TabItem Header="Label Inspection">
                <local:CameraPanel DataContext="{Binding Cameras[0]}"/>
            </TabItem>

            <!-- ===== CAMERA 2 ===== -->
            <TabItem Header="Camera 2">
                <local:CameraPanel DataContext="{Binding Cameras[1]}" Loaded="CameraPanel_Loaded"/>
            </TabItem>

            <!-- ===== CAMERA 3 ===== -->
            <TabItem Header="Camera 3">
                <local:CameraPanel DataContext="{Binding Cameras[2]}"/>
            </TabItem>

            <!-- ===== CAMERA 4 ===== -->
            <TabItem Header="Camera 4">
                <local:CameraPanel DataContext="{Binding Cameras[3]}"/>
            </TabItem>

            <!-- ===== CAMERA 5 ===== -->
            <TabItem Header="Camera 5">
                <local:CameraPanel DataContext="{Binding Cameras[4]}"/>
            </TabItem>

            <!-- ===== SETTINGS (Admin-only, except on first run) ===== -->
            <TabItem Header="Settings"
         Visibility="{Binding Session.IsSettingsTabVisible, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel Orientation="Horizontal" Margin="16">

                        <!-- AD CARD -->
                        <materialDesign:Card Padding="24" Margin="8"
                                 VerticalAlignment="Top" Width="380"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                            <StackPanel>
                                <TextBlock Text="Active Directory" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7"
                               Margin="0,0,0,16"
                               Text="Configure the AD server, domain and which AD group grants each role. On first run anyone can set this up; afterwards only an administrator can change it."/>
                                <Button Content="OPEN AD SETTINGS"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>

                        <!-- LOCAL USERS CARD -->
                        <materialDesign:Card Padding="24" Margin="8"
                                 VerticalAlignment="Top" Width="380"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                            <StackPanel>
                                <TextBlock Text="Local Users" FontSize="18" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" Opacity="0.7"
                               Margin="0,0,0,16"
                               Text="Create local users as a fallback for when Active Directory is unreachable. Disabled by default; enable only if needed."/>
                                <Button Content="OPEN USER MANAGEMENT"
                            Command="{Binding OpenUsersCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            HorizontalAlignment="Left"/>
                            </StackPanel>
                        </materialDesign:Card>

                    </WrapPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
